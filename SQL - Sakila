# Análise de Locações - Sakila

# Objetivo
Analisar o comportamento de locação dos clientes utilizando SQL.

# Tecnologias
- MySQL
- Base Sakila

# Análises realizadas
- Total de locações por cliente
- Categorias mais alugadas

# Exemplo de Query - Categoria mais alugada por cliente.

USE sakila;

SELECT 
r.customer_id AS id_cliente,
cat.category_id AS categoria_filme,
COUNT(*) AS total

FROM rental r
JOIN inventory i ON r.inventory_id = i.inventory_id
JOIN film_category fm ON fm.film_id = i.film_id
JOIN category cat ON fm.category_id = cat.category_id

GROUP BY
r.customer_id,
cat.category_id

ORDER BY
r.customer_id,
total DESC;
